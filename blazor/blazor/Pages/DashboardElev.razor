@page "/DashboardElev"

<PageTitle>DashboardElev</PageTitle>

<h1>Elev Dashboard</h1>

<div class="controls">
    <input placeholder="Søgfelt..."
           @bind="searchText" />

    <select @onchange="SortChanged">
        <option value="date">Sorter efter dato</option>
        <option value="subject">Sorter efter fag</option>
    </select>

    <button class="nav-button" @onclick="GoToStatistik">Se Statistik</button>
</div>

<p>Filtered count: @FilteredTasks.Count()</p>

<div class="task-container">

    @foreach (var task in FilteredTasks)
    {
        <div class="task-row">

            <div class="task-col subject">
                @task.Subject
            </div>

            <div class="task-col topic">
                @task.Topic
            </div>

            <div class="task-col date">
                @task.Date.ToShortDateString()
            </div>

            <div class="task-col button-col">
                <button class="task-button">Se Opgave</button>
            </div>

        </div>
    }

</div>

<div class="change-password-box">
    <h3>Ændre adgangskode</h3>

    <input type="password" placeholder="Ny adgangskode" />
    <input type="password" placeholder="Gentag adgangskode" />

    <button class="save-password-button">Gem ændring</button>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void GoToStatistik()
    {
        Navigation.NavigateTo("/StatistikElev");
    }

    // Temporary TaskItem class for dummy data
    public class TaskItem
    {
        public string Subject { get; set; } = "";
        public string Topic { get; set; } = "";
        public DateTime Date { get; set; }
    }

    private List<TaskItem> Tasks = new();

    private string searchText = "";
    private string currentSort = "date";

    protected override void OnInitialized()
    {
        GetTasks();
    }
    
    // erstat inholdet til api kald
    private void GetTasks()
    {
        Tasks = new List<TaskItem>
        {
            new TaskItem{ Subject="Matematik", Topic="Differentialregning", Date=new DateTime(2026,3,10)},
            new TaskItem{ Subject="Fysik", Topic="Newton Love", Date=new DateTime(2026,3,12)},
            new TaskItem{ Subject="Kemi", Topic="Syre og Base", Date=new DateTime(2026,3,15)},
            new TaskItem{ Subject="Matematik", Topic="Integralregning", Date=new DateTime(2026,3,18)}
        };
    }

    private IEnumerable<TaskItem> FilteredTasks
    {
        get
        {
            var query = Tasks.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(t =>
                    t.Subject.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    t.Topic.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            query = currentSort switch
            {
                "subject" => query.OrderBy(t => t.Subject),
                _ => query.OrderBy(t => t.Date)
            };

            return query;
        }
    }

    private void SortChanged(ChangeEventArgs e)
    {
        currentSort = e.Value?.ToString() ?? "date";
    }
}
